# ── Production Environment Variables ─────────────────────────────
# Bu dosyayi .env olarak kopyalayip tum degerleri guncelleyin.
# ASLA varsayilan degerleri production'da kullanmayin!

# PostgreSQL
POSTGRES_PASSWORD=BURAYA_COK_GUCLU_BIR_SIFRE_YAZIN

# Redis
REDIS_PASSWORD=BURAYA_COK_GUCLU_BIR_REDIS_SIFRESI_YAZIN

# JWT Authentication
JWT_SECRET=EN_AZ_64_KARAKTER_RASTGELE_BIR_SECRET_OLUSTURUN
JWT_EXPIRY=604800

# Admin Panel API Key
ADMIN_API_KEY=BURAYA_COK_GUCLU_BIR_ADMIN_KEY_YAZIN

# CORS - Izin verilen originler (virgülle ayırın)
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# Domain (nginx config'inde kullanilir)
DOMAIN=yourdomain.com

# Database connection pool size (varsayilan: 20)
DB_POOL_SIZE=20

# Frontend URL (davet linkleri icin - protokol dahil)
FRONTEND_URL=https://yourdomain.com
